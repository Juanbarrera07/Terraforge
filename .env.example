# TerraForge Mining Intelligence — environment variables
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.

# USGS EarthExplorer M2M API
USGS_M2M_USERNAME=your_usgs_username
USGS_M2M_PASSWORD=your_usgs_password

# Copernicus Data Space Ecosystem (CDSE) OAuth2
CDSE_CLIENT_ID=your_copernicus_client_id
CDSE_CLIENT_SECRET=your_copernicus_client_secret

# Optional: override default output directories
# TMI_OUTPUT_DIR=./outputs
# TMI_TMP_DIR=./tmp
